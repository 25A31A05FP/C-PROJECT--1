#include <stdio.h>

int main() {
    int score = 0;
    char answer;

    printf("===== MINI QUIZ GAME =====\n\n");

    // Question 1
    printf("1. What is the capital of India?\n");
    printf("a) Mumbai\nb) Delhi\nc) Chennai\nd) Kolkata\n");
